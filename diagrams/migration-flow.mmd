flowchart TB
  subgraph Phase_0["Phase 0 — Audit (1-2 weeks)"]
    Audit["Analyse SF org\n(object counts, data quality,\ncustom objects)"]
  end

  subgraph Phase_1["Phase 1 — Extract (1-3 days)"]
    Extract["Export SF data to S3\n(Bulk API 2.0 → JSONL)"]
  end

  subgraph Phase_2["Phase 2 — Transform (2-5 days)"]
    Transform["Map SF schema → Givernance\n(field mapping, dedup,\nrelationship resolution)"]
  end

  subgraph Phase_3["Phase 3 — Load Dry-Run (1 day)"]
    DryRun["Load to staging env\n+ validation report"]
  end

  subgraph Phase_4["Phase 4 — Reconcile (1-2 days)"]
    Reconcile["Fix transform errors\n+ NPO sign-off"]
  end

  subgraph Phase_5["Phase 5 — Cutover (1 day)"]
    Cutover["Load to production\n+ final delta from SF"]
  end

  subgraph Phase_6["Phase 6 — Parallel Run (2-4 weeks)"]
    Parallel["Both systems live\nverify data, train staff"]
  end

  subgraph Phase_7["Phase 7 — Decommission (1 week)"]
    GoLive["Freeze SF, archive export\nGivernance goes primary"]
  end

  Audit --> Extract
  Extract --> Transform
  Transform --> DryRun
  DryRun --> Reconcile
  Reconcile -->|issues found| Transform
  Reconcile -->|sign-off OK| Cutover
  Cutover --> Parallel
  Parallel --> GoLive
  Cutover -.->|critical failure| Rollback["Rollback\n(restore pre-load snapshot)"]

  subgraph MigrationAssistant["Migration Assistant UX (wizard)"]
    direction LR
    Step1["1. Connect SF\n(OAuth read-only)"]
    Step2["2. Analyse Data\n(compatibility score)"]
    Step3["3. Map Fields\n(visual mapper + AI)"]
    Step4["4. Preview\n(dry-run + HTML report)"]
    Step5["5. Migrate\n(production load)"]
    Step1 --> Step2 --> Step3 --> Step4 --> Step5
  end
